// Burden Note — local-first DB schema (Prisma 7)
// Datasource URL lives in prisma.config.ts; the schema only declares the provider.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  color     String?
  createdAt DateTime @default(now())

  cards            BurdenCard[]
  gratitudesOut    Gratitude[]      @relation("GratitudeFrom")
  gratitudesIn     Gratitude[]      @relation("GratitudeTo")
  weeklyFeedbacks  WeeklyFeedback[]
}

model BurdenCard {
  id        String @id @default(cuid())
  authorId  String
  author    User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // What happened — single CATEGORIES.
  title       String
  category    String
  privateText String?

  // What KIND of burden — JSON array (LOAD_TYPES).
  loadTypes   String @default("[]")

  // Who carried it — BEARERS.
  bearer     String

  // Felt weight — WEIGHTS. Never aggregate across people.
  weight     String

  // What got drained as a result — JSON array (DEPLETED).
  depleted   String @default("[]")

  // How visible was this to the partner — VISIBILITY.
  visibility String

  // What does the writer want done with this — JSON array (NEEDS).
  needs      String @default("[]")

  // Sharing pipeline: private → candidate → shared.
  sharing     String    @default("private")
  shareText   String?
  rephrasedAt DateTime?

  // AI-generated guidance, written alongside shareText. Optional so older cards stay readable.
  appreciation String?   // 相手への労い・感謝の言葉
  selfCare     String?   // 入力者自身への労い (相手向けではない)
  adviceTip    String?   // 次の会話で意識すると良い一言アドバイス

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([authorId, occurredAt])
  @@index([sharing])
}

model Gratitude {
  id             String    @id @default(cuid())
  fromUserId     String
  toUserId       String
  fromUser       User      @relation("GratitudeFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser         User      @relation("GratitudeTo", fields: [toUserId], references: [id], onDelete: Cascade)
  text           String
  cardId         String?
  // How the gratitude was created. Only ack'd rows count toward the sparkline.
  source         String    @default("button") // button | ai_draft | manual
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([toUserId, createdAt])
  @@index([toUserId, acknowledgedAt])
}

model WeeklyPick {
  id           String   @id @default(cuid())
  weekStart    DateTime
  pickedBurden String
  nextAction   String?
  note         String?
  // Filled by the weekly LLM. Shared content for both partners.
  whatWorked   String?
  nextMove     String?
  createdAt    DateTime @default(now())

  @@unique([weekStart])
}

// Per-user weekly observation generated by the LLM and per-user self-report.
// One row per (week, user) — the two partners get two rows.
model WeeklyFeedback {
  id               String   @id @default(cuid())
  weekStart        DateTime
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  observation      String
  gentleNotice     String
  feltAcknowledged String?  // none | a_little | yes — self-reported only, never aggregated
  generatedAt      DateTime @default(now())

  @@unique([weekStart, userId])
}
