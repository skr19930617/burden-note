# SQLite local DB. Named with a BURDEN_ prefix so it doesn't collide with
# any DATABASE_URL your shell may export for other projects.
BURDEN_DATABASE_URL="file:./dev.db"

# LLM provider — defaults to xAI when XAI_API_KEY is set, else falls back to template adapter
LLM_PROVIDER="xai"           # xai | template | anthropic | openai
XAI_API_KEY=""
XAI_MODEL="grok-4-latest"

# Optional alternatives (adapter ready)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
